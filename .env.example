# =============================================================================
# CremaCuadrado Backend — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# =============================================================================

# ---------------------------------------------------------------------------
# Base de datos
# ---------------------------------------------------------------------------
# Local:      postgresql://postgres:postgres@localhost:5432/cremacuadrado
# Supabase:   postgresql://postgres.<project>:<password-url-encoded>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cremacuadrado

# ---------------------------------------------------------------------------
# Seguridad
# ---------------------------------------------------------------------------
# Genera con: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_min_64_chars

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# Aplicación
# ---------------------------------------------------------------------------
DEBUG=True   # False en producción

# Orígenes permitidos en CORS — lista JSON, sin espacios entre elementos
# Local:      ["http://localhost:4200","http://127.0.0.1:4200"]
# Producción: ["https://cremacuadrado-front.vercel.app"]
CORS_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200"]

# Hosts permitidos (TrustedHostMiddleware). Usa ["*"] en local.
# Producción: ["cremacuadrado-back.vercel.app"]
ALLOWED_HOSTS=["*"]

# URL pública del frontend — usada en emails (links de confirmación, reset, etc.)
# Local:      http://localhost:4200
# Producción: https://cremacuadrado-front.vercel.app
SITE_URL=http://localhost:4200

# URL base del backend — usada para construir URLs absolutas de imágenes estáticas.
# Dejar vacío para URLs relativas (recomendado en producción con el rewrite de Vercel).
# Local: http://localhost:8000
# Producción: dejar vacío o https://cremacuadrado-back.vercel.app
BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Admin
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@cremacuadrado.com
ADMIN_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Email (SMTP) — dos buzones: Pedidos@ (transaccional) e Info@ (todo lo demás)
# ---------------------------------------------------------------------------
EMAIL_ENABLED=False

# Pedidos@cremacuadrado.com — confirmación de pedido, fallo de pago, envío, factura
# Si se deja vacío, cae automáticamente en el buzón Info@ (ver app/services/email.py)
SMTP_PEDIDOS_HOST=smtp.titan.email
SMTP_PEDIDOS_PORT=587
SMTP_PEDIDOS_USER=
SMTP_PEDIDOS_PASSWORD=
SMTP_PEDIDOS_FROM_EMAIL=Pedidos@cremacuadrado.com
SMTP_PEDIDOS_FROM_NAME=CremaCuadrado Pedidos

# Info@cremacuadrado.com — bienvenida, verificación, seguridad, newsletter, contacto, B2B, todo lo demás
SMTP_INFO_HOST=smtp.titan.email
SMTP_INFO_PORT=587
SMTP_INFO_USER=
SMTP_INFO_PASSWORD=
SMTP_INFO_FROM_EMAIL=info@cremacuadrado.com
SMTP_INFO_FROM_NAME=CremaCuadrado

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=   # console.cloud.google.com → APIs & Services → Credentials

# ---------------------------------------------------------------------------
# Vercel Blob (almacenamiento de imágenes)
# URL pública base del blob store (para construir URLs absolutas desde la BD)
# Siempre la misma en dev y prod — es un CDN público
# Encuéntrala en: Vercel Dashboard → Storage → tu Blob store → Settings
BLOB_BASE_URL=https://r2azgdghbvayayn4.public.blob.vercel-storage.com

# ---------------------------------------------------------------------------
BLOB_PUBLIC_READ_WRITE_TOKEN=vercel_blob_rw_...
