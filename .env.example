# Environment variables for local development
# Copy to .env and update values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cremacuadrado

# JWT - CHANGE IN PRODUCTION! Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_A_RANDOM_64_CHAR_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — add your frontend Vercel URL in production
# e.g. CORS_ORIGINS=["https://cremacuadrado-front.vercel.app"]
CORS_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200"]

# Trusted hosts — set your backend Vercel domain in production to prevent Host header injection
# e.g. ALLOWED_HOSTS=["cremacuadrado-back.vercel.app"]
ALLOWED_HOSTS=["*"]

# Application
# Set DEBUG=false in production — hides /docs, /redoc and /openapi.json
DEBUG=true
APP_NAME=Cremacuadrado API
APP_VERSION=1.0.0

# Email (MVP: disabled, logs to console)
EMAIL_ENABLED=false
EMAIL_FROM=info@cremacuadrado.com

# Shipping
SHIPPING_COST=4.95
FREE_SHIPPING_THRESHOLD=50.0

# Tax
TAX_RATE=0.21

# Admin (initial credentials - CHANGE IMMEDIATELY after first login)
ADMIN_EMAIL=admin@cremacuadrado.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
